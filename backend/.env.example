# Copy this file to `.env` in the same folder (backend/.env) and fill in your keys.
# .env is already git-ignored -- never commit real keys.

# Which provider /chatbot/explain should try first: "groq" or "gemini"
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys) -- free tier, fast, good default
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (https://aistudio.google.com/apikey) -- used if Groq fails/unset
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
